# Golden-snapshot fixtures share extensions with workbench output (which is gitignored above)
# but must be tracked. Negate the ignores within testdata/golden/.
!testdata/golden/
!testdata/golden/**

# Bindgen behavior-test fixtures live in bindgen/testdata/generated/ and must be tracked.
!bindgen/testdata/
!bindgen/testdata/**

# kernel-matrix min_kernel floor-check fixtures share the *.report.json extension
