          "bpf_program_load",
          "perf_event_open"
        ],
        "features": [
          "tracefs"
        ]
      },
      "helper_effects": [
        {
          "name": "bpf.current_comm",
          "observes": [
            "task.comm"
          ]
        },
        {
          "name": "bpf.current_pid",
          "observes": [
            "task.tgid"
          ]
        },
        {
          "name": "bpf.current_ppid",
          "observes": [
            "task.real_parent.tgid"
          ],
          "requires": [
            "task_struct.real_parent"
          ]
        },
        {
          "name": "bpf.current_uid",
          "observes": [
            "task.uid"
          ]
        },
        {
          "name": "bpf.ktime_get_ns",
          "observes": [
            "kernel.time.monotonic"
          ]
        },
        {
          "name": "ringbuf.reserve",
          "mutates": [
            "ringbuf:ExecEvents"
          ],
          "resource": "reserve"
        },
        {
          "name": "ringbuf.submit",
          "mutates": [
            "ringbuf:ExecEvents"
          ],
          "resource": "submit"
        }
      ]
    }
  ],
