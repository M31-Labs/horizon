{
  "schema": "m31labs.dev/horizon/capability/v1",
  "package": "probes",
  "programs": [
    {
      "name": "OnExec",
      "kind": "tracepoint",
      "attach": "sched:sched_process_exec",
      "section": "tracepoint/sched:sched_process_exec",
      "capabilities": [
        "kernel.process.exec.observe"
      ]
    }
