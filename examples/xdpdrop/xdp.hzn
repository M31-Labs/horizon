package probes

type (
    Port = u16
)

const (
    HTTPS Port = 443
)

capability DropCapability danger drop = "kernel.network.xdp.drop"

@capability(DropCapability)
@xdp
func DropTCP(ctx xdp.Context) i32 {
    tcp := xdp.tcp(ctx)
    if tcp == nil {
        return xdp.Pass
    }
    switch xdp.ntohs(tcp.dst_port) {
        case HTTPS:
            return xdp.Drop
        default:
            return xdp.Pass
    }
}
